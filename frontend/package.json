{
  "name": "degrading-anxiety-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "api:generate": "openapi-typescript https://aws.naroah.top/degrading-anxiety/openapi.json -o app/src/lib/api/schema.d.ts",
    "app:build": "pnpm --filter @degrading-anxiety/app prepack",
    "dev:web": "pnpm app:build && pnpm --filter @degrading-anxiety/web dev",
    "dev:desktop": "pnpm app:build && pnpm --filter @degrading-anxiety/desktop tauri dev",
    "build:web": "pnpm app:build && pnpm --filter @degrading-anxiety/web build",
    "build:desktop": "pnpm app:build && pnpm --filter @degrading-anxiety/desktop tauri build",
    "check": "pnpm -r check"
  },
  "devDependencies": {
    "@unocss/extractor-svelte": "^66.7.3",
    "openapi-typescript": "^7.13.0",
    "unocss": "^66.7.3"
  }
}
